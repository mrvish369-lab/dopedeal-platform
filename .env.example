# ─────────────────────────────────────────────────────────────────────────────
# DopeDeal — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Frontend — safe to expose) ─────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: used for QR code URL generation
VITE_SUPABASE_PROJECT_ID=your-project-id

# ── Email (Frontend — sender address only, no secrets) ───────────────────────
# The verified sender domain configured in Resend
VITE_RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# Edge Function Secrets (set via Supabase CLI, NOT in .env)
# Run: supabase secrets set RESEND_API_KEY=re_xxxx FROM_EMAIL=noreply@yourdomain.com
# ─────────────────────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx   ← Resend API key (server-side only)
# FROM_EMAIL=noreply@yourdomain.com        ← Verified sender address
# LOVABLE_API_KEY=...                      ← AI gateway key (optional)
